{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yuyukosama2004/eval42/schemas/v1/config.schema.json",
  "title": "Eval42 Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "dataset",
    "adapter",
    "execution_policy",
    "metrics",
    "gates",
    "report"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "revision"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "include_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "exclude_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "base_url", "endpoint"],
      "properties": {
        "type": {
          "const": "http"
        },
        "base_url": {
          "type": "string",
          "minLength": 1
        },
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "enum": ["GET", "POST"],
          "default": "POST"
        },
        "timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 60
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_completion_rate", "retries", "max_retryable_error_rate"],
      "properties": {
        "min_completion_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "max_retryable_error_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["metric"],
        "properties": {
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          },
          "max_regression": {
            "type": "number",
            "minimum": 0
          },
          "max_relative_regression": {
            "type": "number",
            "minimum": 0
          },
          "scope": {
            "enum": ["aggregate", "every_case"]
          },
          "severity": {
            "enum": ["error", "warning", "info"]
          }
        },
        "anyOf": [
          {
            "required": ["min"]
          },
          {
            "required": ["max"]
          },
          {
            "required": ["max_regression"]
          },
          {
            "required": ["max_relative_regression"]
          }
        ]
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formats", "output_dir"],
      "properties": {
        "formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["json", "markdown"]
          },
          "uniqueItems": true
        },
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "include_inputs": {
          "type": "boolean",
          "default": true
        },
        "include_answers": {
          "type": "boolean",
          "default": false
        },
        "include_retrieved_content": {
          "type": "boolean",
          "default": false
        },
        "include_claims": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "run_budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_cases": {
          "type": "integer",
          "minimum": 1
        },
        "max_duration_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_estimated_cost": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        }
      }
    }
  }
}
