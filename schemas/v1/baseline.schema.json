{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yuyukosama2004/eval42/schemas/v1/baseline.schema.json",
  "title": "Eval42 Baseline v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_name",
    "created_at",
    "dataset",
    "run_fingerprint",
    "summary",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "hash"],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "run_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_revision",
        "adapter_version",
        "eval42_version",
        "config_hash",
        "metric_hash",
        "environment"
      ],
      "properties": {
        "target_revision": {
          "type": "string",
          "minLength": 1
        },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "eval42_version": {
          "type": "string",
          "minLength": 1
        },
        "config_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "metric_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "metric_version": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "case_hash", "status", "metrics"],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "case_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "status": {
            "enum": ["completed", "error"]
          },
          "metrics": {
            "type": "object"
          }
        }
      }
    }
  }
}
